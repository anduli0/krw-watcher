# ============================================================================
# KRW-Watcher — PRODUCTION ENVIRONMENT TEMPLATE
# ============================================================================
# Copy this file to `.env` on your production host (or paste these keys into
# your PaaS dashboard's env-var settings). DO NOT commit the filled-in file.
# This template contains NO real secrets — fill in the blanks/placeholders.
#
# ----------------------------------------------------------------------------
# PRODUCTION SECURITY CHECKLIST  (do these before going live)
# ----------------------------------------------------------------------------
#   [ ] Run `python setup.py` to generate & fill:
#         - JWT_SECRET           (>= 32 random chars)
#         - ADMIN_PASSWORD_HASH  (bcrypt hash of your admin password)
#         - OWNER_MAC            (your device MAC, if you use MAC binding)
#   [ ] DEV_MODE=false                  (auth + IP gating enforced)
#   [ ] Keep live trading OFF for a public deploy:
#         - BROKER=paper
#         - ENABLE_LIVE_TRADING=false
#         - KIS_PAPER=true
#   [ ] Set ALLOWED_IPS to your IP/CIDR list to lock the site down,
#         or leave "*" to keep read endpoints public (admin/cycle/briefing
#         still require login or X-Cron-Secret).
#   [ ] Provide DATABASE_URL pointing at managed Postgres (not SQLite).
#   [ ] Provide CRON_SECRET if an external scheduler will trigger cycles.
#   [ ] NEVER bake this file into a Docker image or commit it to git
#         (it must be in .dockerignore and .gitignore).
#
# ----------------------------------------------------------------------------
# DEPLOY CONSTRAINT — SINGLE WORKER ONLY
# ----------------------------------------------------------------------------
#   The app holds in-memory state (activity_log, runtime_state, data cache,
#   broker singleton) and runs an APScheduler in its lifespan. Running 2+
#   workers/replicas would run the scheduler N times (N× Anthropic token burn)
#   and split state. Always start with exactly one worker:
#
#       uvicorn backend.main:app --host 0.0.0.0 --port $PORT --workers 1
#
#   (Omitting --workers also works; uvicorn defaults to 1.)
#   NEVER use gunicorn -w>1. NEVER scale replicas > 1.
# ============================================================================


# ----------------------------------------------------------------------------
# RUNTIME / SERVER
# ----------------------------------------------------------------------------
# DEV_MODE=false enforces authentication and IP gating in production.
DEV_MODE=false
# Most PaaS platforms inject $PORT automatically. The app defaults to 8010
# if PORT is unset. Set it explicitly only if your platform does not inject it.
PORT=8010
# Anthropic model id used by the agent committee. Leave blank to use the
# app's built-in default.
MODEL_ID=


# ----------------------------------------------------------------------------
# AI / DATA PROVIDER KEYS  (REQUIRED for live cycles)
# ----------------------------------------------------------------------------
# Anthropic API key — PAID. The 23-agent committee burns tokens every cycle.
ANTHROPIC_API_KEY=
# FRED (St. Louis Fed) API key — macro/rates/spot fallback data.
FRED_API_KEY=
# Bank of Korea ECOS API key — KRW-side macro data.
BOK_ECOS_KEY=


# ----------------------------------------------------------------------------
# TELEGRAM  (optional — daily briefing + real-time alerts)
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ----------------------------------------------------------------------------
# AUTH / SECURITY  (fill via `python setup.py` — do NOT hand-write)
# ----------------------------------------------------------------------------
# JWT signing secret — MUST be >= 32 random chars.
JWT_SECRET=
# bcrypt hash of the admin password (generated by setup.py).
ADMIN_PASSWORD_HASH=
# Your device MAC for optional owner-MAC binding (generated/prompted by setup.py).
OWNER_MAC=
# IP allow-list. "*" makes read endpoints public (admin/cycle/briefing still
# require login or X-Cron-Secret). Narrow this to your IPs/CIDRs to lock down:
#   ALLOWED_IPS=203.0.113.7,198.51.100.0/24
ALLOWED_IPS=*
# CORS allowed origins (comma-separated). Set to your dashboard origin(s),
# e.g. https://krw.example.com . Leave blank if same-origin only.
CORS_ORIGINS=
# Shared secret for external cron triggers. Senders pass it as the
# X-Cron-Secret header to call /api/cycle or /api/briefing/generate without
# an admin login. Leave blank to disable header-based cron triggering.
CRON_SECRET=


# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------
# Production uses managed Postgres. init_db.py normalizes postgres:// →
# postgresql+asyncpg:// and handles sslmode; asyncpg is in requirements.txt.
# Example (replace USER/PASS/HOST/DB):
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/DB


# ----------------------------------------------------------------------------
# SCHEDULER / CYCLE CONTROL
# ----------------------------------------------------------------------------
# false = run the full AI prediction cycle on schedule (burns Anthropic tokens).
# true  = free, data-only read-only mirror (NO token-burning AI cycles).
DISABLE_AUTO_CYCLE=false
# Hour (KST, 0-23) at which the daily briefing is generated/sent.
BRIEFING_HOUR_KST=8


# ----------------------------------------------------------------------------
# BROKER / TRADING  (KEEP OFF for a public deploy)
# ----------------------------------------------------------------------------
# Broker backend. Use "paper" for a public deploy. Other backends route real
# orders and must stay disabled unless you fully intend live trading.
BROKER=paper
# Master kill-switch for sending real orders. Keep false for a public deploy.
ENABLE_LIVE_TRADING=false

# --- Korea Investment & Securities (KIS) credentials ---
# Only needed if you switch BROKER to a KIS backend. Leave blank for paper.
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
# true = KIS paper/sandbox endpoint (safe). false = KIS live endpoint.
KIS_PAPER=true

# --- Risk limits (apply to whichever broker is active) ---
# Max notional (USD) for a single trade.
MAX_TRADE_NOTIONAL_USD=
# Max total open notional (USD) across all positions.
MAX_TOTAL_NOTIONAL_USD=
# Daily realized-loss limit (KRW); breaching it halts further trading for the day.
DAILY_LOSS_LIMIT_KRW=
