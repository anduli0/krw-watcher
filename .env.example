# ── Core ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MODEL_ID=claude-sonnet-4-6

# ── Macro data ───────────────────────────────────────────────────────────────
# FRED (US + USD/KRW spot via DEXKOUS, dollar index, VIX, CNY). Free key:
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Bank of Korea ECOS (한국은행 경제통계시스템) — base rate, KR CPI, current account.
# Optional. Free key: https://ecos.bok.or.kr/api/
BOK_ECOS_KEY=

# ── Trading bridge (future broker integration) ────────────────────────────────
# Which adapter to use: "paper" (simulated) | "kis" (한국투자증권 KIS Developers)
BROKER=paper
# KIS Developers REST credentials — only needed when BROKER=kis
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
# true = 모의투자 도메인, false = 실전투자 도메인
KIS_PAPER=true

# Hard ceiling on a SINGLE auto-trade notional (USD). The engine NEVER exceeds this.
MAX_TRADE_NOTIONAL_USD=10000
# Portfolio-level risk limits.
MAX_TOTAL_NOTIONAL_USD=30000
DAILY_LOSS_LIMIT_KRW=2000000
# Set true ONLY after you have validated paper-trading. Gate for live orders.
ENABLE_LIVE_TRADING=false

# ── Telegram daily brief delivery ──
# Bot token from @BotFather; CHAT_ID = your chat (DM the bot, then /getUpdates).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BRIEFING_HOUR_KST=8

# ── Security (run `python setup.py` to populate for production) ──
# JWT signing secret (≥32 chars). ADMIN_PASSWORD_HASH = bcrypt hash of your login password.
# OWNER_MAC = hardware lock. ALLOWED_IPS = CSV whitelist ("*" = open/cloud).
JWT_SECRET=
ADMIN_PASSWORD_HASH=
OWNER_MAC=
ALLOWED_IPS=127.0.0.1
DATABASE_URL=sqlite+aiosqlite:///./krw_watcher.db

# ── Dev ──────────────────────────────────────────────────────────────────────
# DEV_MODE=true bypasses MAC + JWT (IP whitelist still applies). Set false in production.
DEV_MODE=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3010
